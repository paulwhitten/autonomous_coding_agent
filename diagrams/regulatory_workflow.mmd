flowchart TD
    START(( )) --> REQ["REQUIREMENTS_DEFINITION<br/>RA"]
    REQ -->|peer route to Developer| IMPL["IMPLEMENTING<br/>Developer"]
    IMPL -->|peer route to QA| VER["VERIFICATION<br/>QA"]
    VER -->|"exitEvaluation: PASS<br/>peer route to RA"| ACC["ACCEPTANCE<br/>RA"]
    VER -->|"exitEvaluation: FAIL<br/>peer route to Developer"| REWORK["REWORK<br/>Developer"]
    REWORK -->|peer route to QA| VER
    REWORK -->|"onFailure (retries exhausted)"| ESC
    ACC -->|"exitEvaluation: ACCEPTED"| DONE["DONE<br/>(terminal)"]
    ACC -->|"exitEvaluation: REJECTED<br/>peer route to Developer"| REWORK2["REWORK_ACCEPTANCE<br/>Developer"]
    REWORK2 -->|peer route to QA| VER
    REWORK2 -->|"onFailure (retries exhausted)"| ESC["ESCALATED<br/>(terminal)"]
    DONE --> END(( ))
    ESC --> END
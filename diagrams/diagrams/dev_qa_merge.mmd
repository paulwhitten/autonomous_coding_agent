flowchart TD
    START(( )) --> ASSIGN["ASSIGN<br/>Manager"]

    ASSIGN -->|"route to Developer"| IMPL["IMPLEMENTING<br/>Developer"]
    ASSIGN -->|onFailure| ESC

    IMPL -->|"exitEvaluation: pass"| VAL["VALIDATING<br/>QA"]
    IMPL -->|"exitEvaluation: fail<br/>(up to 2 retries)"| IMPL

    VAL -->|"exitEvaluation: pass"| MERGE["MERGING<br/>QA"]
    VAL -->|"exitEvaluation: fail"| REWORK["REWORK<br/>Developer"]

    REWORK -->|"exitEvaluation: pass"| VAL
    REWORK -->|"retries exhausted"| ESC

    MERGE -->|onSuccess| DONE["DONE<br/>(terminal)"]
    MERGE -->|onFailure| ESC["ESCALATED<br/>(terminal)"]

    DONE --> END(( ))
    ESC --> END

    style IMPL fill:#d4edda,stroke:#28a745
    style VAL fill:#cce5ff,stroke:#0d6efd
    style REWORK fill:#fff3cd,stroke:#ffc107
    style MERGE fill:#cce5ff,stroke:#0d6efd
    style DONE fill:#d1e7dd,stroke:#198754
    style ESC fill:#f8d7da,stroke:#dc3545

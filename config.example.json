{
  "$schema": "./config.schema.json",

  // ╔══════════════════════════════════════════════════════════════════════╗
  // ║  Convention over Configuration                                      ║
  // ║                                                                     ║
  // ║  Only agent.role and mailbox.repoPath are required.                 ║
  // ║  Everything else has sensible defaults (see config-defaults.ts).    ║
  // ║  This file shows every available option for reference.              ║
  // ║  The effective config (defaults + your overrides) is logged on      ║
  // ║  startup and on every hot-reload.                                   ║
  // ╚══════════════════════════════════════════════════════════════════════╝
  //
  // Minimal config to get started:
  //
  //   {
  //     "agent": { "role": "developer" },
  //     "mailbox": { "repoPath": "../agent_project_template/template_mailbox_repo" }
  //   }

  "agent": {
    "hostname": "auto-detect",             // Default: os.hostname()
    "role": "researcher",                  // REQUIRED: "developer" | "qa" | "manager" | "researcher"
    "roleDefinitionsFile": "./roles.json", // Default: "./roles.json"

    // Timing configuration (all have sensible defaults)
    // "checkIntervalMs": 60000,           // Default: 60000 (1 min) -- mailbox polling interval
    // "stuckTimeoutMs": 2700000,          // Default: 2700000 (45 min) -- stuck/WIP watchdog
    // "sdkTimeoutMs": 300000,             // Default: 300000 (5 min) -- SDK call timeout

    // Retry configuration
    // "taskRetryCount": 3,                // Default: 3

    // Work item decomposition range
    // "minWorkItems": 5,                  // Default: 5
    // "maxWorkItems": 20,                 // Default: 20

    // Free-form decomposition guidance
    // "decompositionPrompt": "Always include a dedicated work item for writing unit tests.",

    // Adaptive timeout strategy (defaults shown)
    // "timeoutStrategy": {
    //   "enabled": true,
    //   "tier1_multiplier": 1.5,
    //   "tier2_backgroundThreshold": 2,
    //   "tier3_decomposeThreshold": 3,
    //   "tier4_adaptiveWindow": 3600000,
    //   "tier4_adaptiveThreshold": 5
    // },

    // Validation and review configuration (defaults shown)
    // "validation": {
    //   "mode": "spot_check",             // "none" | "spot_check" | "always" | "milestone"
    //   "reviewEveryNthItem": 5,
    //   "milestones": []
    // }

    // Backpressure (defaults shown)
    // "backpressure": {
    //   "enabled": true,
    //   "maxPendingWorkItems": 50,
    //   "maxRecipientMailbox": 10,
    //   "deferralLogIntervalMs": 300000
    // }
  },
  "mailbox": {
    "repoPath": "../agent_project_template/template_mailbox_repo"  // REQUIRED
    // "gitSync": false,                   // Default: false; set true for multi-agent git sync
    // "autoCommit": true,                 // Default: true
    // "commitMessage": "Auto-sync: {hostname}_{role} at {timestamp}",
    // "supportBroadcast": true,           // Default: true
    // "supportAttachments": true,         // Default: true
    // "supportPriority": true             // Default: true
  },

  // All copilot fields have defaults -- omit the entire block to use them
  // "copilot": {
  //   "model": "gpt-4.1",                // Default: "gpt-4.1"
  //   "allowedTools": ["all"],            // Default: ["all"]
  //   "permissions": {
  //     "shell": "allowlist",             // Default: "allowlist"
  //     "write": "allow",                 // Default: "allow"
  //     "read": "allow",                  // Default: "allow"
  //     "url": "deny",                    // Default: "deny"
  //     "mcp": "deny"                     // Default: "deny"
  //   }
  // },

  // All workspace fields have defaults -- omit the entire block to use them
  // "workspace": {
  //   "path": "./workspace",              // Default: "./workspace"
  //   "tasksFolder": "tasks",             // Default: "tasks"
  //   "workingFolder": "project",         // Default: "project"
  //   "taskSubfolders": {                 // Defaults shown
  //     "pending": "pending",
  //     "completed": "completed",
  //     "review": "review",
  //     "failed": "failed"
  //   },
  //   "persistContext": true,             // Default: true
  //   "projectRepo": "file:///path/to/repo"  // Optional: git clone URL; cloned into workingFolder on first start
  // },

  // All logging fields have defaults -- omit the entire block to use them
  // "logging": {
  //   "level": "info",                    // Default: "info"
  //   "path": "./logs/agent.log",         // Default: "./logs/agent.log"
  //   "maxSizeMB": 100                    // Default: 100
  // },

  // Manager -- omit for default manager settings, or when this agent IS the manager
  // "manager": {
  //   "hostname": "i9",
  //   "role": "manager",
  //   "escalationPriority": "HIGH"        // Default: "HIGH"
  // },

  // Quota -- defaults to enabled with adaptive preset
  // "quota": {
  //   "enabled": true,                    // Default: true
  //   "preset": "adaptive",              // Default: "adaptive"
  //   "presetsFile": "./quota-presets.json"
  // },

  // Communication -- both git mailbox and A2A HTTP are always active.
  // Add a "communication.a2a" block only to override defaults:
  // "communication": {
  //   "a2a": {
  //     "serverPort": 4000,
  //     "transport": "jsonrpc",
  //     "tls": { "enabled": false },
  //     "authentication": { "scheme": "none" },
  //     "knownAgentUrls": [],
  //     "auditDir": "audit/a2a"
  //   }
  // },

  // Team member routing
  "teamMembers": []
}

{
  "agent": {
    "hostname": "smoke-reg-mgr",
    "role": "manager",
    "checkIntervalMs": 5000,
    "stuckTimeoutMs": 2700000,
    "sdkTimeoutMs": 120000,
    "taskRetryCount": 2,
    "workflowFile": "../../workflow.json",
    "timeoutStrategy": {
      "enabled": true,
      "tier1_multiplier": 1.5,
      "tier2_backgroundThreshold": 2,
      "tier3_decomposeThreshold": 3,
      "tier4_adaptiveWindow": 3600000,
      "tier4_adaptiveThreshold": 3
    },
    "validation": {
      "mode": "none",
      "reviewEveryNthItem": 99,
      "milestones": []
    }
  },
  "mailbox": {
    "repoPath": "../../runtime_mailbox",
    "gitSync": true,
    "autoCommit": true,
    "supportBroadcast": false,
    "supportAttachments": false,
    "supportPriority": true
  },
  "copilot": {
    "model": "gpt-4.1",
    "allowedTools": ["all"]
  },
  "workspace": {
    "path": "./workspace",
    "tasksFolder": "tasks",
    "workingFolder": "project",
    "taskSubfolders": {
      "pending": "pending",
      "completed": "completed",
      "review": "review",
      "failed": "failed"
    },
    "persistContext": true
  },
  "logging": {
    "level": "info",
    "path": "./logs/agent.log",
    "maxSizeMB": 100
  },
  "manager": null,
  "teamMembers": [
    {
      "hostname": "smoke-reg-ra",
      "role": "requirements-analyst",
      "responsibilities": "Define requirements (REQUIREMENTS_DEFINITION) and validate final delivery (ACCEPTANCE)"
    },
    {
      "hostname": "smoke-reg-dev",
      "role": "developer",
      "responsibilities": "Implement code against requirements (IMPLEMENTING) and fix rework (REWORK)"
    },
    {
      "hostname": "smoke-reg-qa",
      "role": "qa",
      "responsibilities": "Verify implementation against requirements (VERIFICATION)"
    }
  ],
  "quota": {
    "enabled": false,
    "preset": "development",
    "presetsFile": "./quota-presets.json"
  }
}

{
  "$schema": "../../workflows/workflow.schema.json",
  "id": "wip-smoke-workflow",
  "name": "WIP Limit Smoke Test Workflow",
  "description": "Minimal workflow for testing WIP limit gate. Manager assigns, developer implements, then done.",
  "version": "1.0.0",
  "initialState": "ASSIGN",
  "terminalStates": ["DONE"],
  "globalContext": {
    "projectPath": "workspace/project"
  },
  "states": {
    "ASSIGN": {
      "name": "Task Assignment",
      "role": "manager",
      "description": "Manager delegates a task to the developer via mechanical routing.",
      "prompt": "",
      "allowedTools": [],
      "transitions": {
        "onSuccess": "IMPLEMENTING",
        "onFailure": "DONE"
      }
    },
    "IMPLEMENTING": {
      "name": "Implementation",
      "role": "developer",
      "description": "Developer implements the task.",
      "prompt": "Implement the assigned task.\n\n1. Create a proof file in workspace\n2. Report completion",
      "allowedTools": ["terminal", "file_ops", "reporting"],
      "transitions": {
        "onSuccess": "DONE",
        "onFailure": "DONE"
      },
      "timeoutMs": 300000
    },
    "DONE": {
      "name": "Complete",
      "role": "manager",
      "description": "Task is complete.",
      "prompt": "",
      "allowedTools": [],
      "transitions": {
        "onSuccess": null,
        "onFailure": null
      }
    }
  }
}

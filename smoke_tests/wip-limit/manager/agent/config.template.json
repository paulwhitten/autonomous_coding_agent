{
  "agent": {
    "hostname": "smoke-wip-mgr",
    "role": "manager",
    "checkIntervalMs": 5000,
    "stuckTimeoutMs": 120000,
    "taskRetryCount": 2,
    "workflowFile": "../../workflow.json",
    "wipLimit": 2,
    "validation": {
      "mode": "none",
      "reviewEveryNthItem": 99
    }
  },
  "mailbox": {
    "repoPath": "../runtime_mailbox",

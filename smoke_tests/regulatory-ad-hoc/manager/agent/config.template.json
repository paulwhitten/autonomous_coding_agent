{
  "agent": {
    "hostname": "smoke-regah-mgr",
    "role": "manager",
    "checkIntervalMs": 5000,
    "taskRetryCount": 2,
    "validation": {
      "mode": "none",
      "reviewEveryNthItem": 99
    }
  },
  "copilot": {
    "model": "gpt-5-mini"
  },
  "mailbox": {
    "repoPath": "../../runtime_mailbox",
    "gitSync": true,
    "supportBroadcast": false,
    "supportAttachments": false
  },
  "manager": null,
  "teamMembers": [
    {
      "hostname": "smoke-regah-ra",
      "role": "requirements-analyst",
      "responsibilities": "Define requirements (REQUIREMENTS_DEFINITION) and validate final delivery (ACCEPTANCE)"
    },
    {
      "hostname": "smoke-regah-dev",
      "role": "developer",
      "responsibilities": "Implement code against requirements (IMPLEMENTING) and fix rework (REWORK)"
    },
    {
      "hostname": "smoke-regah-qa",
      "role": "qa",
      "responsibilities": "Verify implementation against requirements (VERIFICATION)"
    }
  ],
  "quota": {
    "enabled": false
  }
}

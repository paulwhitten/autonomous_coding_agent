{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/autonomous-copilot-agent/config.schema.json",
  "title": "Autonomous Copilot Agent Configuration",
  "description": "Convention over Configuration: only agent.role and mailbox.repoPath are required. All other fields have sensible defaults defined in src/config-defaults.ts.",
  "type": "object",
  "required": ["agent", "mailbox"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation."
    },
    "agent": {
      "type": "object",
      "description": "Agent identity, timing, and behavior settings.",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "hostname": {
          "type": "string",
          "default": "auto-detect",
          "description": "Agent hostname. 'auto-detect' resolves to os.hostname() at startup."
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "description": "REQUIRED. The agent's role. Built-in roles: developer, qa, manager, researcher, requirements-analyst. Custom roles are also supported."
        },
        "roleDefinitionsFile": {
          "type": "string",
          "default": "./roles.json",
          "description": "Path to role definitions (relative to config.json or absolute)."
        },
        "customRolesFile": {
          "type": "string",
          "description": "Path to custom roles overlay JSON, merged on top of roleDefinitionsFile."
        },
        "customInstructionsFile": {
          "type": "string",
          "description": "Path to custom_instructions.json for project-specific overlays."
        },
        "workflowFile": {
          "type": "string",
          "description": "Path to a .workflow.json file for workflow-driven execution."
        },
        "checkIntervalMs": {
          "type": "integer",
          "default": 60000,
          "description": "Mailbox polling interval in ms. Values below 20000 risk rate-limiting in production."
        },
        "stuckTimeoutMs": {
          "type": "integer",
          "default": 2700000,
          "description": "Stuck/WIP watchdog timeout in ms (default: 45 minutes)."
        },
        "sdkTimeoutMs": {
          "type": "integer",
          "default": 300000,
          "description": "Base timeout for Copilot SDK calls in ms (default: 5 minutes)."
        },
        "taskRetryCount": {
          "type": "integer",
          "default": 3,
          "minimum": 0,
          "description": "Number of retries for failed work items."
        },
        "minWorkItems": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Minimum work items when decomposing a task."
        },
        "maxWorkItems": {
          "type": "integer",
          "default": 20,
          "minimum": 1,
          "description": "Maximum work items when decomposing a task."
        },
        "decompositionPrompt": {
          "type": "string",
          "description": "Free-form guidance injected into every decomposition prompt."
        },
        "backpressure": {
          "type": "object",
          "description": "Backpressure settings to prevent overloading agents.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "maxPendingWorkItems": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "description": "Max pending work items before deferring new messages."
            },
            "maxRecipientMailbox": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "description": "Max unread messages in recipient mailbox before sender backs off."
            },
            "deferralLogIntervalMs": {
              "type": "integer",
              "default": 300000,
              "description": "Min interval between backpressure log warnings (ms)."
            }
          }
        },
        "timeoutStrategy": {
          "type": "object",
          "description": "Multi-tier adaptive timeout handling.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "tier1_multiplier": {
              "type": "number",
              "default": 1.5,
              "description": "Multiply timeout by this factor on each retry."
            },
            "tier2_backgroundThreshold": {
              "type": "integer",
              "default": 2,
              "description": "After N timeouts, switch to background pattern."
            },
            "tier3_decomposeThreshold": {
              "type": "integer",
              "default": 3,
              "description": "After N timeouts, recommend decomposition."
            },
            "tier4_adaptiveWindow": {
              "type": "integer",
              "default": 3600000,
              "description": "Pattern detection window in ms (default: 1 hour)."
            },
            "tier4_adaptiveThreshold": {
              "type": "integer",
              "default": 5,
              "description": "Timeouts within window before suggesting global increase."
            }
          }
        },
        "validation": {
          "type": "object",
          "description": "Work item validation and review configuration.",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "spot_check", "milestone", "always"],
              "default": "spot_check",
              "description": "Validation mode for completed work items."
            },
            "reviewEveryNthItem": {
              "type": "integer",
              "default": 5,
              "minimum": 1,
              "description": "For spot_check: review every Nth completed item."
            },
            "milestones": {
              "type": "array",
              "items": { "type": "integer" },
              "default": [],
              "description": "For milestone mode: which sequence numbers to review."
            }
          }
        },
        "wipLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Max concurrent in-flight delegations for manager role. 0 = disabled."
        }
      }
    },
    "mailbox": {
      "type": "object",
      "description": "Git mailbox settings for inter-agent communication.",
      "required": ["repoPath"],
      "additionalProperties": false,
      "properties": {
        "repoPath": {
          "type": "string",
          "description": "REQUIRED. Path to the mailbox directory (or git repository when gitSync is enabled)."
        },
        "gitSync": {
          "type": "boolean",
          "default": false,
          "description": "Enable git pull/push for remote multi-agent collaboration. Default: false (plain folders)."
        },
        "autoCommit": {
          "type": "boolean",
          "default": true,
          "description": "Auto-commit mailbox changes."
        },
        "commitMessage": {
          "type": "string",
          "default": "Auto-sync: {hostname}_{role} at {timestamp}",
          "description": "Template for auto-commit messages. Supports {hostname}, {role}, {timestamp}."
        },
        "supportBroadcast": {
          "type": "boolean",
          "default": true,
          "description": "Enable broadcast messages (to_all/ folder)."
        },
        "supportAttachments": {
          "type": "boolean",
          "default": true,
          "description": "Enable attachment folder support."
        },
        "supportPriority": {
          "type": "boolean",
          "default": true,
          "description": "Enable priority/normal/background mailbox folders."
        },
        "teamRosterFile": {
          "type": "string",
          "description": "Path to team.json roster file for team discovery."
        }
      }
    },
    "copilot": {
      "type": "object",
      "description": "Copilot SDK and model settings.",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "LLM model identifier (e.g., gpt-4.1, gpt-5, claude-sonnet-4.5)."
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for the LLM (0-2)."
        },
        "streaming": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses from the LLM."
        },
        "allowedTools": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            { "const": "all" }
          ],
          "default": ["all"],
          "description": "Copilot tool access: [\"all\"] or specific tool names."
        },
        "permissions": {
          "type": "object",
          "description": "SDK permission handler configuration.",
          "properties": {
            "shell": {
              "type": "string",
              "enum": ["allowlist", "allow", "deny"],
              "default": "allowlist",
              "description": "Shell access: allowlist (common dev tools), allow (any), deny."
            },
            "write": {
              "type": "string",
              "enum": ["allow", "deny", "workingDir"],
              "default": "allow",
              "description": "File write operations."
            },
            "read": {
              "type": "string",
              "enum": ["allow", "deny", "workingDir"],
              "default": "allow",
              "description": "File read operations."
            },
            "url": {
              "type": "string",
              "enum": ["allow", "deny"],
              "default": "deny",
              "description": "URL/network access."
            },
            "mcp": {
              "type": "string",
              "enum": ["allow", "deny"],
              "default": "deny",
              "description": "MCP server tool calls."
            },
            "shellAllowAdditional": {
              "type": "array",
              "items": { "type": "string" },
              "default": [],
              "description": "Extra shell commands beyond the built-in dev allowlist."
            }
          }
        }
      }
    },
    "workspace": {
      "type": "object",
      "description": "Workspace directory structure.",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "default": "./workspace",
          "description": "Root workspace directory."
        },
        "tasksFolder": {
          "type": "string",
          "default": "tasks",
          "description": "Subfolder for work item management."
        },
        "workingFolder": {
          "type": "string",
          "default": "project",
          "description": "Subfolder for generated code/artifacts."
        },
        "taskSubfolders": {
          "type": "object",
          "description": "Customizable task subfolder names.",
          "additionalProperties": false,
          "properties": {
            "pending": { "type": "string", "default": "pending" },
            "completed": { "type": "string", "default": "completed" },
            "review": { "type": "string", "default": "review" },
            "failed": { "type": "string", "default": "failed" }
          }
        },
        "persistContext": {
          "type": "boolean",
          "default": true,
          "description": "Save session context across restarts."
        },
        "projectRepo": {
          "type": "string",
          "description": "Git repository URL to clone into the working folder on first startup. Supports https://, git@, and file:// URLs. The clone is skipped if the working folder already contains a .git directory."
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration.",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Log verbosity level."
        },
        "path": {
          "type": "string",
          "default": "./logs/agent.log",
          "description": "Log file path."
        },
        "maxSizeMB": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "description": "Max log file size before rotation (MB)."
        }
      }
    },
    "manager": {
      "oneOf": [
        {
          "type": "object",
          "description": "Manager agent identity. Omit or set to null when this agent IS the manager.",
          "additionalProperties": false,
          "properties": {
            "hostname": {
              "type": "string",
              "description": "Manager agent hostname."
            },
            "role": {
              "type": "string",
              "default": "manager",
              "description": "Manager agent role."
            },
            "escalationPriority": {
              "type": "string",
              "enum": ["HIGH", "NORMAL", "LOW"],
              "default": "HIGH",
              "description": "Priority for escalation messages to the manager."
            },
            "uri": {
              "type": "string",
              "description": "Transport URI for the manager (defaults to mailbox)."
            }
          }
        },
        { "type": "null" }
      ]
    },
    "quota": {
      "type": "object",
      "description": "Quota management settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable quota management."
        },
        "preset": {
          "type": "string",
          "default": "adaptive",
          "description": "Quota preset: conservative, moderate, adaptive, unlimited."
        },
        "presetsFile": {
          "type": "string",
          "default": "./quota-presets.json",
          "description": "Path to quota presets configuration file."
        },
        "overrides": {
          "type": "object",
          "description": "Override specific quota limits."
        },
        "sharedQuotaUrl": {
          "type": "string",
          "description": "URL for shared quota monitoring (e.g., GitHub billing page)."
        }
      }
    },
    "communication": {
      "type": "object",
      "description": "Communication backend overrides. Both mailbox and A2A are always active.",
      "additionalProperties": false,
      "properties": {
        "a2a": {
          "type": "object",
          "description": "A2A HTTP server overrides. Omit to use all defaults.",
          "additionalProperties": false,
          "properties": {
            "serverPort": {
              "type": "integer",
              "default": 4000,
              "description": "HTTP port (0 for OS-assigned)."
            },
            "agentCardPath": {
              "type": "string",
              "default": "/.well-known/agent-card.json"
            },
            "transport": {
              "type": "string",
              "enum": ["jsonrpc", "rest", "grpc"],
              "default": "jsonrpc"
            },
            "agentCard": {
              "type": "object",
              "description": "Customizable agent card fields.",
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "version": { "type": "string", "default": "1.0.0" },
                "provider": {
                  "type": "object",
                  "properties": {
                    "organization": { "type": "string" },
                    "url": { "type": "string" }
                  }
                },
                "inputModes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": ["text/plain"]
                },
                "outputModes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": ["text/plain"]
                }
              }
            },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": false },
                "certPath": { "type": "string" },
                "keyPath": { "type": "string" }
              }
            },
            "authentication": {
              "type": "object",
              "properties": {
                "scheme": {
                  "type": "string",
                  "enum": ["bearer", "apiKey", "none"],
                  "default": "none"
                },
                "token": { "type": "string" },
                "headerName": { "type": "string" }
              }
            },
            "pushNotifications": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": false },
                "webhookUrl": { "type": "string" }
              }
            },
            "knownAgentUrls": {
              "type": "array",
              "items": { "type": "string" },
              "default": [],
              "description": "URLs of known A2A agents for direct discovery."
            },
            "registryUrl": {
              "type": "string",
              "description": "Registry URL for catalog-based discovery."
            },
            "auditDir": {
              "type": "string",
              "default": "audit/a2a",
              "description": "Directory for git-backed audit logs."
            }
          }
        }
      }
    },
    "teamMembers": {
      "type": "array",
      "default": [],
      "description": "Team member routing table.",
      "items": {
        "type": "object",
        "required": ["hostname", "role", "responsibilities"],
        "properties": {
          "hostname": { "type": "string" },
          "role": { "type": "string" },
          "responsibilities": { "type": "string" },
          "uri": {
            "type": "string",
            "description": "Transport URI: a2a://host:port, mailbox://id, or omit for default."
          }
        }
      }
    }
  }
}

# Example environment configuration
# Copy this to .env and customize for your setup

# Agent identification
AGENT_HOSTNAME=pcw-dpm16
AGENT_ROLE=developer

# Mailbox configuration  
MAILBOX_BASE_PATH=../2025-12-external-mailbox/mailbox
MAILBOX_CHECK_INTERVAL=1800000

# Workspace
AGENT_WORKSPACE_PATH=./workspace

# Copilot configuration
COPILOT_MODEL=gpt-4.1

# Optional: GitHub token (if needed)
# GITHUB_TOKEN=your_token_here

{
  "name": "autonomous_copilot_agent",
  "version": "1.0.0",
  "description": "Autonomous coding agent with external mailbox integration using GitHub Copilot SDK",
  "main": "src/index.ts",
  "scripts": {
    "start": "npm run build && node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "start:compiled": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check-mailbox": "tsx scripts/check-mailbox.ts",
    "generate-instructions": "tsx scripts/generate-instructions.ts",
    "quota-status": "tsx scripts/quota-status.ts",
    "workflow:diagram": "tsx scripts/workflow-to-mermaid.ts --all",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "echo '⚠️ No linter configured yet' && exit 0",
    "start:api": "tsx src/api/index.ts",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:web": "cd web && npm run dev",
    "dev:ui": "./scripts/start-ui.sh",
    "build:web": "cd web && npm run build"
  },
  "keywords": [
    "copilot",
    "autonomous-agent",
    "ai",
    "coding-agent",
    "mailbox"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "0.1.29",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "ajv": "^8.18.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "memfs": "^4.56.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
